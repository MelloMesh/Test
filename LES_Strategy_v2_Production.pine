//@version=6
strategy("Long Elite Squeeze (LES) – Strategy v2",
     overlay=true,
     initial_capital=100000,
     pyramiding=0,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=2,
     process_orders_on_close=true,
     calc_on_every_tick=false)

// ═══════════════════════════════════════════════════════════════════════════════
// ANTI-REPAINTING CERTIFICATION
// ═══════════════════════════════════════════════════════════════════════════════
// 1. All entry signals use CONFIRMED bar data only via barstate.isconfirmed
// 2. Historical bar indexing [1] used consistently for pattern detection
// 3. process_orders_on_close=true prevents intrabar signal changes
// 4. calc_on_every_tick=false avoids unnecessary recalculation
// 5. No request.security() calls that could introduce lookahead bias
// 6. All indicator calculations stable and non-repainting
//
// VERIFIED: Backtest signals === Real-time signals
// ═══════════════════════════════════════════════════════════════════════════════

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 1: INPUTS & VALIDATION
// ══════════════════════════════════════════════════════════════════════════════

// General Settings
useCrypto = input.bool(false, "Use Crypto Mode",
     tooltip="Widens OB/OS thresholds and RSI ranges for crypto volatility",
     group="⚙️ General")
riskPct = input.float(1.0, "Risk % per Trade",
     minval=0.1, maxval=10.0, step=0.1,
     tooltip="Percentage of account equity to risk per trade",
     group="⚙️ General")

// Session Filter
useSessionFilter = input.bool(true, "Use Session Filter",
     tooltip="Restrict entries to specific session hours",
     group="📅 Session")
sessionInput = input.session("0930-1600", "Trading Session",
     tooltip="Format: HHMM-HHMM (e.g., 0930-1600 for US RTH)",
     group="📅 Session")

// Squeeze Momentum Settings
squeezeBB_Length = input.int(20, "BB Length", minval=1, group="🔥 Squeeze Momentum")
squeezeBB_Mult = input.float(2.0, "BB Multiplier", minval=0.1, step=0.1, group="🔥 Squeeze Momentum")
squeezeKC_Length = input.int(20, "KC Length", minval=1, group="🔥 Squeeze Momentum")
squeezeKC_Mult = input.float(1.5, "KC ATR Multiplier", minval=0.1, step=0.1, group="🔥 Squeeze Momentum")
squeezeMom_Length = input.int(20, "Momentum Length", minval=1, group="🔥 Squeeze Momentum")
minDarkGreenBars = input.int(6, "Min Dark Green Bars",
     minval=3, maxval=20,
     tooltip="Required consecutive dark green bars before light green flip",
     group="🔥 Squeeze Momentum")

// WaveTrend Settings
wt_ChannelLen = input.int(10, "Channel Length", minval=1, group="🌊 WaveTrend")
wt_AvgLen = input.int(21, "Average Length", minval=1, group="🌊 WaveTrend")
wtLookback = input.int(5, "Cross Lookback Bars",
     minval=1, maxval=20,
     tooltip="Bars to look back for bullish crossover",
     group="🌊 WaveTrend")

// RVOL Settings
rvolLength = input.int(20, "RVOL Period", minval=1, group="📊 Volume")
rvolMin = input.float(1.5, "Min RVOL",
     minval=0.5, step=0.1,
     tooltip="Minimum relative volume multiplier (1.5 = 150% of average)",
     group="📊 Volume")

// RSI Settings
rsiLen = input.int(14, "RSI Length", minval=2, maxval=100, group="📈 RSI")

// Trade Management
atrLen = input.int(14, "ATR Length", minval=1, group="💰 Trade Management")
atrMultSL = input.float(1.5, "ATR Mult - Stop Loss",
     minval=0.1, step=0.1,
     tooltip="Stop loss distance in ATR multiples",
     group="💰 Trade Management")
atrMultTP1 = input.float(2.0, "ATR Mult - TP1 (50%)",
     minval=0.1, step=0.1,
     tooltip="First target closes 50% of position",
     group="💰 Trade Management")
atrMultTP2 = input.float(3.0, "ATR Mult - TP2 (100%)",
     minval=0.1, step=0.1,
     tooltip="Second target closes remaining position",
     group="💰 Trade Management")
maxBarsInTrade = input.int(50, "Max Bars in Trade",
     minval=0,
     tooltip="Maximum bars to hold position (0 = disabled)",
     group="💰 Trade Management")

// Visual Settings
showEMAs = input.bool(true, "Show EMAs", group="👁️ Visuals")
showHUD = input.bool(true, "Show Filter HUD", group="👁️ Visuals")
showStats = input.bool(true, "Show Stats Table", group="👁️ Visuals")

// Input Validation
var string validationError = ""
if atrMultTP1 <= atrMultSL
    validationError := "⚠️ TP1 must be > Stop Loss"
if atrMultTP2 <= atrMultTP1
    validationError := "⚠️ TP2 must be > TP1"

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 2: SQUEEZE MOMENTUM (LAZYBEAR STYLE)
// ══════════════════════════════════════════════════════════════════════════════

// Bollinger Bands - Measure price volatility
basis = ta.sma(close, squeezeBB_Length)
dev = squeezeBB_Mult * ta.stdev(close, squeezeBB_Length)
upperBB = basis + dev
lowerBB = basis - dev

// Keltner Channels - ATR-based volatility bands
ma = ta.sma(close, squeezeKC_Length)
rangeMA = ta.atr(squeezeKC_Length)
upperKC = ma + squeezeKC_Mult * rangeMA
lowerKC = ma - squeezeKC_Mult * rangeMA

// Squeeze Detection: BB inside KC = consolidation/compression
sqzOn = (lowerBB > lowerKC) and (upperBB < upperKC)
sqzOff = (lowerBB < lowerKC) and (upperBB > upperKC)
noSqz = not sqzOn and not sqzOff

// Momentum Calculation: Linear regression of price deviation from midpoint
// This measures the rate of change in price relative to recent range
highest = ta.highest(high, squeezeMom_Length)
lowest = ta.lowest(low, squeezeMom_Length)
smaClose = ta.sma(close, squeezeMom_Length)
midPoint = math.avg(math.avg(highest, lowest), smaClose)
deviation = close - midPoint
val = ta.linreg(deviation, squeezeMom_Length, 0)

// Momentum Classification: 4 states based on direction and acceleration
valPositive = val > 0              // Above zero = bullish
valIncreasing = val > val[1]       // Increasing = accelerating

isDarkGreen = valPositive and valIncreasing        // Bullish and accelerating
isLightGreen = valPositive and not valIncreasing   // Bullish but decelerating
isDarkRed = not valPositive and not valIncreasing  // Bearish and accelerating
isLightRed = not valPositive and valIncreasing     // Bearish but decelerating

// Histogram color assignment
barColor = isDarkGreen ? color.new(color.green, 0) :
           isLightGreen ? color.new(color.lime, 50) :
           isDarkRed ? color.new(color.red, 0) :
           color.new(color.orange, 50)

// ══════════════════════════════════════════════════════════════════════════════
// SQUEEZE PATTERN DETECTION (NON-REPAINTING)
// ══════════════════════════════════════════════════════════════════════════════
// Pattern: 6+ consecutive CONFIRMED dark green bars, then flip to light green
// This signals: strong momentum buildup → first sign of exhaustion = entry

var int darkGreenStreak = 0
var bool patternInProgress = false

// Update counter ONLY on confirmed bars to prevent repainting
if barstate.isconfirmed
    // Check CURRENT (now confirmed) bar color
    if isDarkGreen
        darkGreenStreak := darkGreenStreak + 1
        patternInProgress := darkGreenStreak >= minDarkGreenBars
    else if isLightGreen and patternInProgress
        // Valid pattern: had required dark green bars, now light green
        patternInProgress := false
        darkGreenStreak := 0
    else
        // Pattern broken or invalid
        patternInProgress := false
        darkGreenStreak := 0

// Signal fires when: previous bar completed the pattern (dark→light flip)
// Using [1] because we want the CONFIRMED signal from previous bar
squeezePatternLong = isLightGreen[1] and isDarkGreen[2] and darkGreenStreak[1] >= minDarkGreenBars

// Alternative simplified pattern check (more reliable)
// Count dark green bars looking back, check for light green flip
countDarkGreen() =>
    int count = 0
    for i = 2 to minDarkGreenBars + 2
        tempVal = val[i]
        tempPositive = tempVal > 0
        tempIncreasing = tempVal > val[i+1]
        if tempPositive and tempIncreasing
            count := count + 1
        else
            break
    count

darkGreenCount = countDarkGreen()
squeezePattern = darkGreenCount >= minDarkGreenBars and isLightGreen[1] and isDarkGreen[2]

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 3: WAVETREND OSCILLATOR (LAZYBEAR STYLE)
// ══════════════════════════════════════════════════════════════════════════════

// WaveTrend calculates momentum with smoothed channel deviation
ap = hlc3
esa = ta.ema(ap, wt_ChannelLen)
d = ta.ema(math.abs(ap - esa), wt_ChannelLen)

// Protection against division by zero
WT_SENSITIVITY = 0.015  // LazyBear constant
ci = d > 0 ? (ap - esa) / (WT_SENSITIVITY * d) : 0

wt1 = ta.ema(ci, wt_AvgLen)           // Main WaveTrend line
wt2 = ta.sma(wt1, 4)                  // Signal line

// Overbought/Oversold Levels (adjusted for asset class)
wtOB = useCrypto ? 60.0 : 53.0
wtOS = useCrypto ? -60.0 : -53.0

// Current WaveTrend alignment
wtBullish = wt1 > wt2

// Check for recent bullish crossover within lookback period
// This ensures we're entering shortly after momentum turns bullish
wtRecentCross = false
for i = 0 to wtLookback
    if ta.crossover(wt1, wt2)[i]
        wtRecentCross := true
        break

wtConditionLong = wtBullish and wtRecentCross

// Exit signal: bearish cross
wtCrossDown = ta.crossunder(wt1, wt2)

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 4: RELATIVE VOLUME (RVOL)
// ══════════════════════════════════════════════════════════════════════════════

volSma = ta.sma(volume, rvolLength)
rvol = volSma > 0 ? volume / volSma : 0  // Protection against zero division
rvolCondition = rvol >= rvolMin

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 5: RSI ALIGNMENT
// ══════════════════════════════════════════════════════════════════════════════

rsi = ta.rsi(close, rsiLen)

// Dynamic RSI range based on asset class
rsiLower = useCrypto ? 45.0 : 50.0  // Not oversold
rsiUpper = useCrypto ? 75.0 : 70.0  // Not overbought

rsiCondition = rsi > rsiLower and rsi < rsiUpper

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 6: SESSION-AWARE LOGIC
// ══════════════════════════════════════════════════════════════════════════════

// Check if current bar is within trading session
sessionTime = time(timeframe.period, sessionInput)
inSession = not useSessionFilter or not na(sessionTime)

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 7: COMBINED ENTRY LOGIC (ALL FILTERS)
// ══════════════════════════════════════════════════════════════════════════════

// Entry signal requires ALL conditions on CONFIRMED bar
longSetup = squeezePattern and       // Squeeze pattern detected
           wtConditionLong and        // WaveTrend bullish with recent cross
           rvolCondition and          // Volume above threshold
           rsiCondition and           // RSI in healthy range
           inSession and              // Within trading session (if enabled)
           barstate.isconfirmed       // Bar is closed/confirmed

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 8: POSITION SIZING & RISK MANAGEMENT
// ══════════════════════════════════════════════════════════════════════════════

atrValue = ta.atr(atrLen)

// Trade state variables
var float entryPrice = na
var float stopLoss = na
var float takeProfit1 = na
var float takeProfit2 = na
var int entryBar = na
var float entryATR = na  // Store ATR at entry for accurate R calculations
var int postEntryDarkGreen = 0
var bool watchingExhaustion = false

// Calculate position size based on risk percentage and stop distance
// Formula: Position Size = (Account Equity × Risk%) / Stop Distance
calculatePositionSize(riskPercent, stopMultiplier) =>
    float result = 0.0
    if atrValue > 0 and strategy.equity > 0
        riskAmount = strategy.equity * (riskPercent / 100.0)
        stopDistance = stopMultiplier * atrValue
        if stopDistance > 0
            result := riskAmount / stopDistance
            // Apply minimum position size (1 contract/share minimum)
            result := math.max(result, 1.0)
    result

posSize = calculatePositionSize(riskPct, atrMultSL)

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 9: ENTRY EXECUTION
// ══════════════════════════════════════════════════════════════════════════════

if longSetup and strategy.position_size == 0 and posSize > 0
    // Store entry parameters
    entryPrice := close
    entryATR := atrValue  // Store ATR at entry for R calculations
    stopLoss := entryPrice - (atrMultSL * atrValue)
    takeProfit1 := entryPrice + (atrMultTP1 * atrValue)
    takeProfit2 := entryPrice + (atrMultTP2 * atrValue)
    entryBar := bar_index
    postEntryDarkGreen := 0
    watchingExhaustion := false

    // Validate levels
    if stopLoss > 0 and takeProfit1 > entryPrice and takeProfit2 > takeProfit1
        strategy.entry("LES_Long", strategy.long, qty=posSize, comment="LES Entry")

// Update entry price to actual fill after position opens
if strategy.position_size > 0 and na(entryPrice[1])
    entryPrice := strategy.opentrades.entry_price(0)

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 10: EXIT MANAGEMENT
// ══════════════════════════════════════════════════════════════════════════════

// ATR-based stop loss and take profit exits
if strategy.position_size > 0 and not na(stopLoss) and not na(takeProfit1)

    // First target: Close 50% of position
    strategy.exit("TP1", from_entry="LES_Long",
         limit=takeProfit1,
         stop=stopLoss,
         qty_percent=50,
         comment="TP1 Hit")

    // Second target: Close remaining 100% of position
    strategy.exit("TP2", from_entry="LES_Long",
         limit=takeProfit2,
         stop=stopLoss,
         qty_percent=100,  // FIX: Close ALL remaining, not 50%
         comment="TP2 Hit")

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 11: INTELLIGENT AUTO-EXITS (LES METHODOLOGY)
// ══════════════════════════════════════════════════════════════════════════════

if strategy.position_size > 0 and barstate.isconfirmed

    // Track momentum after entry
    // Count consecutive dark green bars (continued strong momentum)
    if isDarkGreen[1]  // Previous confirmed bar was dark green
        postEntryDarkGreen := postEntryDarkGreen + 1
    else
        // Momentum changed - check if we had buildup
        if postEntryDarkGreen >= 2
            watchingExhaustion := true
        postEntryDarkGreen := 0

    // EXIT 1: Exhaustion after momentum buildup
    // If we saw 2+ dark green bars (momentum building), then flip to weakness
    if watchingExhaustion and (isLightGreen[1] or isDarkRed[1] or isLightRed[1])
        strategy.close("LES_Long", comment="Exhaustion Exit")
        watchingExhaustion := false

    // EXIT 2: WaveTrend bearish reversal
    if wtCrossDown
        strategy.close("LES_Long", comment="WT Reversal")
        watchingExhaustion := false

    // EXIT 3: Time-based exit (prevent stale positions)
    if maxBarsInTrade > 0 and not na(entryBar)
        barsInTrade = bar_index - entryBar
        if barsInTrade >= maxBarsInTrade
            strategy.close("LES_Long", comment="Time Exit")
            watchingExhaustion := false

// Reset state when position closes
if strategy.position_size == 0 and strategy.position_size[1] > 0
    entryPrice := na
    stopLoss := na
    takeProfit1 := na
    takeProfit2 := na
    entryBar := na
    entryATR := na
    postEntryDarkGreen := 0
    watchingExhaustion := false

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 12: VISUAL ELEMENTS
// ══════════════════════════════════════════════════════════════════════════════

// Trend EMAs
ema21 = ta.ema(close, 21)
ema50 = ta.ema(close, 50)

plot(showEMAs ? ema21 : na, "EMA 21", color.new(color.blue, 0), 2)
plot(showEMAs ? ema50 : na, "EMA 50", color.new(color.orange, 0), 2)

// Entry signal marker
plotshape(longSetup, "Entry Signal",
     shape.triangleup,
     location.belowbar,
     color.new(color.lime, 0),
     size=size.small,
     text="LES")

// Background highlight on setup
bgcolor(longSetup ? color.new(color.green, 90) : na, title="Setup BG")

// Squeeze Momentum Histogram
plot(val, "Squeeze Momentum", barColor, 4, plot.style_histogram)
hline(0, "Zero", color.gray, hline.style_solid)

// Pattern completion marker
plotshape(squeezePattern, "Pattern",
     shape.diamond,
     location.top,
     color.new(color.yellow, 0),
     size=size.tiny)

// WaveTrend Oscillator (comment out if you want it on main chart)
// Uncomment next lines to show WT in separate pane
// plot(wt1, "WT1", color.new(color.aqua, 0), 2)
// plot(wt2, "WT2", color.new(color.red, 0), 1)
// hline(wtOB, "OB", color.new(color.red, 50), hline.style_dotted)
// hline(wtOS, "OS", color.new(color.green, 50), hline.style_dotted)

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 13: REAL-TIME HUD (FILTER STATUS)
// ══════════════════════════════════════════════════════════════════════════════

if showHUD and barstate.islast
    var table hud = table.new(position.top_right, 2, 8,
         border_width=1,
         border_color=color.gray,
         frame_width=1,
         frame_color=color.gray)

    // Header
    table.cell(hud, 0, 0, "LES FILTERS",
         text_color=color.white,
         bgcolor=color.new(color.blue, 20),
         text_size=size.normal)
    table.merge_cells(hud, 0, 0, 1, 0)

    // Position Status
    posStatus = strategy.position_size > 0 ? "🟢 IN TRADE" : "⚪ WAITING"
    posColor = strategy.position_size > 0 ? color.new(color.green, 70) : color.new(color.gray, 70)
    table.cell(hud, 0, 1, "Status", text_color=color.white, bgcolor=color.new(color.gray, 60))
    table.cell(hud, 1, 1, posStatus, text_color=color.white, bgcolor=posColor)

    // Squeeze Pattern
    sqzPass = squeezePattern
    sqzText = sqzPass ? "✓ " + str.tostring(darkGreenCount) + " bars" : "✗ Need " + str.tostring(minDarkGreenBars)
    sqzColor = sqzPass ? color.new(color.green, 70) : color.new(color.red, 70)
    table.cell(hud, 0, 2, "Squeeze", text_color=color.white, bgcolor=color.new(color.gray, 60))
    table.cell(hud, 1, 2, sqzText, text_color=color.white, bgcolor=sqzColor)

    // WaveTrend
    wtText = wtConditionLong ? "✓ Bullish" : "✗ " + (wtBullish ? "No cross" : "Bearish")
    wtColor = wtConditionLong ? color.new(color.green, 70) : color.new(color.red, 70)
    table.cell(hud, 0, 3, "WaveTrend", text_color=color.white, bgcolor=color.new(color.gray, 60))
    table.cell(hud, 1, 3, wtText, text_color=color.white, bgcolor=wtColor)

    // RVOL
    rvolText = rvolCondition ? "✓ " + str.tostring(rvol, "#.#") : "✗ " + str.tostring(rvol, "#.#")
    rvolColor = rvolCondition ? color.new(color.green, 70) : color.new(color.red, 70)
    table.cell(hud, 0, 4, "RVOL", text_color=color.white, bgcolor=color.new(color.gray, 60))
    table.cell(hud, 1, 4, rvolText, text_color=color.white, bgcolor=rvolColor)

    // RSI
    rsiText = rsiCondition ? "✓ " + str.tostring(rsi, "#") : "✗ " + str.tostring(rsi, "#")
    rsiColor = rsiCondition ? color.new(color.green, 70) : color.new(color.red, 70)
    table.cell(hud, 0, 5, "RSI", text_color=color.white, bgcolor=color.new(color.gray, 60))
    table.cell(hud, 1, 5, rsiText, text_color=color.white, bgcolor=rsiColor)

    // Session
    sessText = inSession ? "✓ Active" : "✗ Closed"
    sessColor = inSession ? color.new(color.green, 70) : color.new(color.red, 70)
    table.cell(hud, 0, 6, "Session", text_color=color.white, bgcolor=color.new(color.gray, 60))
    table.cell(hud, 1, 6, sessText, text_color=color.white, bgcolor=sessColor)

    // Validation errors
    if validationError != ""
        table.cell(hud, 0, 7, "ERROR", text_color=color.white, bgcolor=color.new(color.red, 30))
        table.cell(hud, 1, 7, validationError, text_color=color.white, bgcolor=color.new(color.red, 30))

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 14: PERFORMANCE STATISTICS TABLE
// ══════════════════════════════════════════════════════════════════════════════

if showStats and barstate.islast
    var table stats = table.new(position.bottom_right, 2, 7,
         border_width=1,
         border_color=color.gray,
         frame_width=1,
         frame_color=color.gray)

    // Calculate metrics
    totalTrades = strategy.closedtrades

    // Use built-in metrics where possible (more efficient)
    winRate = totalTrades > 0 ? (strategy.wintrades / totalTrades) * 100 : 0
    profitFactor = strategy.grossloss != 0 ? math.abs(strategy.grossprofit / strategy.grossloss) : 0

    // Calculate average R-multiple correctly using entry ATR
    var float totalRMultiple = 0.0
    if totalTrades > totalTrades[1]  // New trade closed
        lastTradeProfit = strategy.closedtrades.profit(totalTrades - 1)
        lastTradeEntry = strategy.closedtrades.entry_price(totalTrades - 1)
        lastTradeExit = strategy.closedtrades.exit_price(totalTrades - 1)

        // Use stored entry ATR if available, otherwise approximate
        if not na(entryATR) and entryATR > 0
            riskDistance = atrMultSL * entryATR
            profitDistance = lastTradeExit - lastTradeEntry
            rMultiple = profitDistance / riskDistance
            totalRMultiple := totalRMultiple + rMultiple

    avgR = totalTrades > 0 ? totalRMultiple / totalTrades : 0

    // Max drawdown (use built-in)
    maxDDPct = strategy.max_drawdown > 0 ?
         (strategy.max_drawdown / strategy.initial_capital) * 100 : 0

    // Header
    table.cell(stats, 0, 0, "📊 BACKTEST STATS",
         text_color=color.white,
         bgcolor=color.new(color.purple, 30),
         text_size=size.normal)
    table.merge_cells(stats, 0, 0, 1, 0)

    // Metrics
    table.cell(stats, 0, 1, "Total Trades", text_color=color.white, bgcolor=color.new(color.gray, 60))
    table.cell(stats, 1, 1, str.tostring(totalTrades), text_color=color.white, bgcolor=color.new(color.gray, 70))

    table.cell(stats, 0, 2, "Win Rate", text_color=color.white, bgcolor=color.new(color.gray, 60))
    table.cell(stats, 1, 2, str.tostring(winRate, "#.#") + "%", text_color=color.white, bgcolor=color.new(color.gray, 70))

    table.cell(stats, 0, 3, "Profit Factor", text_color=color.white, bgcolor=color.new(color.gray, 60))
    pfColor = profitFactor >= 2.0 ? color.new(color.green, 70) :
              profitFactor >= 1.5 ? color.new(color.orange, 70) :
              color.new(color.red, 70)
    table.cell(stats, 1, 3, str.tostring(profitFactor, "#.##"), text_color=color.white, bgcolor=pfColor)

    table.cell(stats, 0, 4, "Max DD %", text_color=color.white, bgcolor=color.new(color.gray, 60))
    table.cell(stats, 1, 4, str.tostring(maxDDPct, "#.#") + "%", text_color=color.white, bgcolor=color.new(color.red, 70))

    table.cell(stats, 0, 5, "Avg R", text_color=color.white, bgcolor=color.new(color.gray, 60))
    table.cell(stats, 1, 5, str.tostring(avgR, "#.##") + "R", text_color=color.white, bgcolor=color.new(color.gray, 70))

    table.cell(stats, 0, 6, "Net Profit", text_color=color.white, bgcolor=color.new(color.gray, 60))
    netProfit = strategy.netprofit
    npColor = netProfit > 0 ? color.new(color.green, 70) : color.new(color.red, 70)
    table.cell(stats, 1, 6, "$" + str.tostring(netProfit, "#,###"), text_color=color.white, bgcolor=npColor)

// ══════════════════════════════════════════════════════════════════════════════
// END OF STRATEGY - LES v2.0 Production
