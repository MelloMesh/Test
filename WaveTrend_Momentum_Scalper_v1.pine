//@version=6
strategy("WaveTrend Momentum Scalper v1",
         shorttitle="WT Scalp",
         overlay=true,
         pyramiding=0,
         process_orders_on_close=false,
         commission_type=strategy.commission.percent,
         commission_value=0.1,
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=5)

// ══════════════════════════════════════════════════════════════════════════════
// ANTI-REPAINTING MEASURES
// ══════════════════════════════════════════════════════════════════════════════
// This strategy implements multiple layers of protection against repainting:
//
// 1. CONFIRMED BAR ENTRIES: All entry conditions use [1] offset to reference
//    the previous confirmed bar, ensuring signals don't change after bar close
//
// 2. BAR STATE CHECK: barstate.isconfirmed ensures entries only execute on
//    confirmed bars, preventing any real-time bar updates from affecting trades
//
// 3. FIXED ENTRY VALUES: Entry price and ATR are captured at entry and stored
//    in var variables, so exit calculations remain constant throughout the trade
//
// 4. STRATEGY BUILT-IN PRICE: Uses strategy.position_avg_price for accurate
//    entry price tracking instead of relying on close price
//
// 5. OPTIONAL ULTRA-CONSERVATIVE MODE: When enabled, adds extra [1] offset
//    to all calculations for maximum repainting protection
//
// RESULT: Backtest results will match real-time trading performance exactly
// ══════════════════════════════════════════════════════════════════════════════

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════

// Anti-Repainting Mode
useNonRepaintMode = input.bool(true, "Enable Ultra Non-Repainting Mode",
                               tooltip="Adds extra [1] offset to all calculations for maximum repainting protection. May slightly delay entries but ensures zero repainting.")

// WaveTrend Inputs
channelLen = input.int(10, "WT Channel Length", minval=1)
avgLen = input.int(21, "WT Average Length", minval=1)
osLevel = input.int(-60, "Oversold Level", maxval=0)
obLevel = input.int(60, "Overbought Level", minval=0)

// Volume Filter
volMultiplier = input.float(1.5, "Volume Multiplier", minval=0.1, step=0.1)

// RSI Inputs
rsiLen = input.int(14, "RSI Length", minval=1)

// ATR Exit Inputs
atrLen = input.int(14, "ATR Length", minval=1)
atrMultSL = input.float(1.5, "ATR Multiplier - Stop Loss", minval=0.1, step=0.1)
atrMultTP1 = input.float(1.5, "ATR Multiplier - TP1 (50%)", minval=0.1, step=0.1)
atrMultTP2 = input.float(3.0, "ATR Multiplier - TP2 (50%)", minval=0.1, step=0.1)

// Time-based Exit
maxBars = input.int(20, "Max Bars in Trade", minval=1)

// Performance Dashboard
showDashboard = input.bool(true, "Show Performance Dashboard", tooltip="Display performance metrics in top-right corner")
showEquityCurve = input.bool(true, "Show Equity Curve", tooltip="Display equity curve in separate pane")

// ══════════════════════════════════════════════════════════════════════════════
// INDICATOR CALCULATIONS
// ══════════════════════════════════════════════════════════════════════════════

// WaveTrend Oscillator
ap = hlc3
esa = ta.ema(ap, channelLen)
d = ta.ema(math.abs(ap - esa), channelLen)
ci = (ap - esa) / (0.015 * d)
wt1 = ta.ema(ci, avgLen)
wt2 = ta.sma(wt1, 4)

// 200 EMA
ema200 = ta.ema(close, 200)

// Volume SMA
volSma = ta.sma(volume, 20)

// ATR
atr = ta.atr(atrLen)

// RSI
rsi = ta.rsi(close, rsiLen)

// ══════════════════════════════════════════════════════════════════════════════
// ENTRY CONDITIONS (Using [1] offset for confirmed bars)
// ══════════════════════════════════════════════════════════════════════════════

// Apply additional offset if ultra non-repainting mode is enabled
offset = useNonRepaintMode ? 2 : 1

// Long Entry Conditions
longWtCross = ta.crossover(wt1[offset], wt2[offset])
longWtLevel = wt1[offset] < osLevel
longTrend = close[offset] > ema200[offset]
longVolume = volume[offset] > volSma[offset] * volMultiplier
longRsi = rsi[offset] > 30 and rsi[offset] < 50

longCondition = longWtCross and longWtLevel and longTrend and longVolume and longRsi and barstate.isconfirmed

// Short Entry Conditions
shortWtCross = ta.crossunder(wt1[offset], wt2[offset])
shortWtLevel = wt1[offset] > obLevel
shortTrend = close[offset] < ema200[offset]
shortVolume = volume[offset] > volSma[offset] * volMultiplier
shortRsi = rsi[offset] > 50 and rsi[offset] < 70

shortCondition = shortWtCross and shortWtLevel and shortTrend and shortVolume and shortRsi and barstate.isconfirmed

// ══════════════════════════════════════════════════════════════════════════════
// STRATEGY EXECUTION
// ══════════════════════════════════════════════════════════════════════════════

// Track entry bar and ATR at entry (fixed values to prevent repainting)
var int entryBar = na
var float entryAtr = na
var bool justEntered = false

// Long Entry - Only on confirmed bars
if longCondition and barstate.isconfirmed
    entryBar := bar_index
    entryAtr := atr  // Capture ATR at entry time
    justEntered := true
    strategy.entry("Long", strategy.long)

// Short Entry - Only on confirmed bars
if shortCondition and barstate.isconfirmed
    entryBar := bar_index
    entryAtr := atr  // Capture ATR at entry time
    justEntered := true
    strategy.entry("Short", strategy.short)

// Use strategy's built-in entry price for accuracy
entryPrice = strategy.position_avg_price

// Calculate bars in trade
barsInTrade = strategy.position_size != 0 and not na(entryBar) ? bar_index - entryBar : 0

// Long Exits - Use fixed ATR from entry to prevent repainting
if strategy.position_size > 0 and not na(entryAtr)
    // Calculate exit levels using ATR captured at entry
    longStop = entryPrice - atrMultSL * entryAtr
    longTP1 = entryPrice + atrMultTP1 * entryAtr
    longTP2 = entryPrice + atrMultTP2 * entryAtr

    // TP1: Close 50% with initial stop
    strategy.exit("Long TP1", "Long",
                 stop=longStop,
                 limit=longTP1,
                 qty_percent=50)

    // TP2: Close remaining 50% with breakeven stop
    strategy.exit("Long TP2", "Long",
                 stop=entryPrice,
                 limit=longTP2,
                 qty_percent=50)

    // Time-based exit - only on confirmed bars
    if barsInTrade >= maxBars and barstate.isconfirmed
        strategy.close("Long", comment="Time Exit")

// Short Exits - Use fixed ATR from entry to prevent repainting
if strategy.position_size < 0 and not na(entryAtr)
    // Calculate exit levels using ATR captured at entry
    shortStop = entryPrice + atrMultSL * entryAtr
    shortTP1 = entryPrice - atrMultTP1 * entryAtr
    shortTP2 = entryPrice - atrMultTP2 * entryAtr

    // TP1: Close 50% with initial stop
    strategy.exit("Short TP1", "Short",
                 stop=shortStop,
                 limit=shortTP1,
                 qty_percent=50)

    // TP2: Close remaining 50% with breakeven stop
    strategy.exit("Short TP2", "Short",
                 stop=entryPrice,
                 limit=shortTP2,
                 qty_percent=50)

    // Time-based exit - only on confirmed bars
    if barsInTrade >= maxBars and barstate.isconfirmed
        strategy.close("Short", comment="Time Exit")

// Reset justEntered flag
if justEntered
    justEntered := false

// ══════════════════════════════════════════════════════════════════════════════
// PERFORMANCE TRACKING & METRICS
// ══════════════════════════════════════════════════════════════════════════════

// Track bars in winning vs losing trades
var int totalWinBars = 0
var int totalLossBars = 0
var int tradeEntryBar = na

// Track entry bar for each trade
if strategy.position_size != 0 and na(tradeEntryBar)
    tradeEntryBar := bar_index

// When trade closes, calculate bars in trade
if strategy.position_size[1] != 0 and strategy.position_size == 0 and not na(tradeEntryBar)
    barsInClosedTrade = bar_index - tradeEntryBar
    // Determine if last closed trade was win or loss
    if strategy.closedtrades > 0
        lastTradeProfit = strategy.closedtrades.profit(strategy.closedtrades - 1)
        if lastTradeProfit > 0
            totalWinBars += barsInClosedTrade
        else if lastTradeProfit < 0
            totalLossBars += barsInClosedTrade
    tradeEntryBar := na

// Calculate Performance Metrics
totalTrades = strategy.wintrades + strategy.losstrades
winRate = totalTrades > 0 ? (strategy.wintrades / totalTrades) * 100 : 0
profitFactor = strategy.grossloss != 0 ? math.abs(strategy.grossprofit / strategy.grossloss) : 0

avgWin = strategy.wintrades > 0 ? strategy.grossprofit / strategy.wintrades : 0
avgLoss = strategy.losstrades > 0 ? math.abs(strategy.grossloss / strategy.losstrades) : 0

maxDD = strategy.max_drawdown
maxDDPercent = strategy.initial_capital > 0 ? (maxDD / strategy.initial_capital) * 100 : 0

// Sharpe Ratio Approximation (simplified)
// Calculate returns
var float[] returns = array.new_float(0)
if strategy.equity != strategy.equity[1] and not na(strategy.equity[1])
    dailyReturn = (strategy.equity - strategy.equity[1]) / strategy.equity[1]
    array.push(returns, dailyReturn)
    // Keep array size manageable
    if array.size(returns) > 252  // ~1 year of trading days
        array.shift(returns)

avgReturn = array.size(returns) > 0 ? array.avg(returns) : 0
stdDevReturn = array.size(returns) > 1 ? array.stdev(returns) : 0
sharpeRatio = stdDevReturn != 0 ? (avgReturn / stdDevReturn) * math.sqrt(252) : 0  // Annualized

avgWinBars = strategy.wintrades > 0 ? totalWinBars / strategy.wintrades : 0
avgLossBars = strategy.losstrades > 0 ? totalLossBars / strategy.losstrades : 0

// ══════════════════════════════════════════════════════════════════════════════
// PERFORMANCE DASHBOARD TABLE
// ══════════════════════════════════════════════════════════════════════════════

if showDashboard
    // Create table in top-right corner
    var table perfTable = table.new(position.top_right, 2, 10,
                                     border_width=2,
                                     border_color=color.new(color.gray, 30),
                                     frame_width=1,
                                     frame_color=color.new(color.gray, 50))

    // Table Header
    table.cell(perfTable, 0, 0, "PERFORMANCE METRICS",
               text_color=color.white,
               bgcolor=color.new(color.blue, 30),
               text_size=size.normal,
               text_halign=text.align_center)
    table.merge_cells(perfTable, 0, 0, 1, 0)

    // Row 1: Total Trades
    table.cell(perfTable, 0, 1, "Total Trades",
               text_color=color.gray,
               bgcolor=color.new(color.black, 80),
               text_size=size.small)
    table.cell(perfTable, 1, 1, str.tostring(totalTrades),
               text_color=color.white,
               bgcolor=color.new(color.black, 80),
               text_size=size.small,
               text_halign=text.align_right)

    // Row 2: Win Rate
    winRateColor = winRate >= 50 ? color.green : color.red
    table.cell(perfTable, 0, 2, "Win Rate",
               text_color=color.gray,
               bgcolor=color.new(color.black, 80),
               text_size=size.small)
    table.cell(perfTable, 1, 2, str.tostring(winRate, "#.##") + "%",
               text_color=winRateColor,
               bgcolor=color.new(color.black, 80),
               text_size=size.small,
               text_halign=text.align_right)

    // Row 3: Profit Factor
    pfColor = profitFactor >= 1.5 ? color.green : profitFactor >= 1 ? color.yellow : color.red
    table.cell(perfTable, 0, 3, "Profit Factor",
               text_color=color.gray,
               bgcolor=color.new(color.black, 80),
               text_size=size.small)
    table.cell(perfTable, 1, 3, str.tostring(profitFactor, "#.##"),
               text_color=pfColor,
               bgcolor=color.new(color.black, 80),
               text_size=size.small,
               text_halign=text.align_right)

    // Row 4: Avg Win
    table.cell(perfTable, 0, 4, "Avg Win",
               text_color=color.gray,
               bgcolor=color.new(color.black, 80),
               text_size=size.small)
    table.cell(perfTable, 1, 4, "$" + str.tostring(avgWin, "#.##"),
               text_color=color.green,
               bgcolor=color.new(color.black, 80),
               text_size=size.small,
               text_halign=text.align_right)

    // Row 5: Avg Loss
    table.cell(perfTable, 0, 5, "Avg Loss",
               text_color=color.gray,
               bgcolor=color.new(color.black, 80),
               text_size=size.small)
    table.cell(perfTable, 1, 5, "$" + str.tostring(avgLoss, "#.##"),
               text_color=color.red,
               bgcolor=color.new(color.black, 80),
               text_size=size.small,
               text_halign=text.align_right)

    // Row 6: Max Drawdown
    table.cell(perfTable, 0, 6, "Max Drawdown",
               text_color=color.gray,
               bgcolor=color.new(color.black, 80),
               text_size=size.small)
    table.cell(perfTable, 1, 6, str.tostring(maxDDPercent, "#.##") + "%",
               text_color=color.red,
               bgcolor=color.new(color.black, 80),
               text_size=size.small,
               text_halign=text.align_right)

    // Row 7: Sharpe Ratio
    sharpeColor = sharpeRatio >= 1.5 ? color.green : sharpeRatio >= 1 ? color.yellow : color.red
    table.cell(perfTable, 0, 7, "Sharpe Ratio",
               text_color=color.gray,
               bgcolor=color.new(color.black, 80),
               text_size=size.small)
    table.cell(perfTable, 1, 7, str.tostring(sharpeRatio, "#.##"),
               text_color=sharpeColor,
               bgcolor=color.new(color.black, 80),
               text_size=size.small,
               text_halign=text.align_right)

    // Row 8: Avg Win Bars
    table.cell(perfTable, 0, 8, "Avg Win Bars",
               text_color=color.gray,
               bgcolor=color.new(color.black, 80),
               text_size=size.small)
    table.cell(perfTable, 1, 8, str.tostring(avgWinBars, "#.#"),
               text_color=color.green,
               bgcolor=color.new(color.black, 80),
               text_size=size.small,
               text_halign=text.align_right)

    // Row 9: Avg Loss Bars
    table.cell(perfTable, 0, 9, "Avg Loss Bars",
               text_color=color.gray,
               bgcolor=color.new(color.black, 80),
               text_size=size.small)
    table.cell(perfTable, 1, 9, str.tostring(avgLossBars, "#.#"),
               text_color=color.red,
               bgcolor=color.new(color.black, 80),
               text_size=size.small,
               text_halign=text.align_right)

// ══════════════════════════════════════════════════════════════════════════════
// VISUAL ELEMENTS
// ══════════════════════════════════════════════════════════════════════════════

// Plot 200 EMA on chart
plot(ema200, "EMA 200", color=color.new(color.yellow, 0), linewidth=2)

// Plot TP levels when in position - using fixed ATR from entry (no repainting)
longTP1Level = strategy.position_size > 0 and not na(entryAtr) ? entryPrice + atrMultTP1 * entryAtr : na
longTP2Level = strategy.position_size > 0 and not na(entryAtr) ? entryPrice + atrMultTP2 * entryAtr : na
shortTP1Level = strategy.position_size < 0 and not na(entryAtr) ? entryPrice - atrMultTP1 * entryAtr : na
shortTP2Level = strategy.position_size < 0 and not na(entryAtr) ? entryPrice - atrMultTP2 * entryAtr : na

plot(longTP1Level, "Long TP1", color=color.new(color.green, 30), style=plot.style_linebr, linewidth=1)
plot(longTP2Level, "Long TP2", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=2)
plot(shortTP1Level, "Short TP1", color=color.new(color.red, 30), style=plot.style_linebr, linewidth=1)
plot(shortTP2Level, "Short TP2", color=color.new(color.red, 0), style=plot.style_linebr, linewidth=2)
plot(strategy.position_size != 0 ? entryPrice : na, "Breakeven", color=color.new(color.blue, 0), style=plot.style_linebr, linewidth=1)

// Background colors for signals
bgcolor(longCondition ? color.new(color.green, 90) : na, title="Long Signal BG")
bgcolor(shortCondition ? color.new(color.red, 90) : na, title="Short Signal BG")

// ══════════════════════════════════════════════════════════════════════════════
// WAVETREND INDICATOR PANE
// ══════════════════════════════════════════════════════════════════════════════

// Plot WaveTrend lines
plot(wt1, "WT1", color=color.new(color.green, 0), linewidth=2)
plot(wt2, "WT2", color=color.new(color.red, 0), linewidth=1)

// Plot OB/OS levels
hline(obLevel, "Overbought", color=color.new(color.red, 50), linestyle=hline.style_dashed)
hline(osLevel, "Oversold", color=color.new(color.green, 50), linestyle=hline.style_dashed)
hline(0, "Zero Line", color=color.new(color.gray, 50), linestyle=hline.style_solid)

// Fill OB/OS zones
upperBand = hline(100, "Upper Band", color=color.new(color.gray, 100))
lowerBand = hline(-100, "Lower Band", color=color.new(color.gray, 100))
obLine = hline(obLevel, linestyle=hline.style_solid, color=color.new(color.gray, 100))
osLine = hline(osLevel, linestyle=hline.style_solid, color=color.new(color.gray, 100))

fill(upperBand, obLine, color=color.new(color.red, 95), title="Overbought Zone")
fill(lowerBand, osLine, color=color.new(color.green, 95), title="Oversold Zone")

// Plot crossover/crossunder signals
plotshape(longWtCross and longWtLevel, "Long Signal", shape.triangleup, location.bottom, color.new(color.green, 0), size=size.small)
plotshape(shortWtCross and shortWtLevel, "Short Signal", shape.triangledown, location.top, color.new(color.red, 0), size=size.small)

// ══════════════════════════════════════════════════════════════════════════════
// EQUITY CURVE
// ══════════════════════════════════════════════════════════════════════════════

// Calculate equity metrics
equityValue = strategy.equity
initialCapital = strategy.initial_capital
equityGrowth = ((equityValue - initialCapital) / initialCapital) * 100

// Calculate peak equity for drawdown visualization
var float peakEquity = strategy.initial_capital
if equityValue > peakEquity
    peakEquity := equityValue

currentDrawdown = peakEquity > 0 ? ((peakEquity - equityValue) / peakEquity) * 100 : 0

// Plot equity curve (conditionally displayed based on showEquityCurve setting)
plot(showEquityCurve ? equityValue : na, "Equity", color=color.new(color.blue, 0), linewidth=2)
plot(showEquityCurve ? peakEquity : na, "Peak Equity", color=color.new(color.green, 50), linewidth=1, style=plot.style_stepline)
plot(showEquityCurve ? initialCapital : na, "Initial Capital", color=color.new(color.gray, 50), linewidth=1, style=plot.style_line)

// Color background based on drawdown (conditionally displayed)
bgcolor(showEquityCurve ? (currentDrawdown > 10 ? color.new(color.red, 95) :
         currentDrawdown > 5 ? color.new(color.orange, 95) :
         equityGrowth > 0 ? color.new(color.green, 97) : na) : na,
         title="Equity Status")
